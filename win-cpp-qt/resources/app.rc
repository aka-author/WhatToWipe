#include <winver.h>

1 ICON "app.ico"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION 1,0,0,37
 PRODUCTVERSION 1,0,0,37
 FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
 FILEFLAGS 0x0L
 FILEOS VOS__WINDOWS32
 FILETYPE VFT_APP
 FILESUBTYPE VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "Erase & Rewrite"
            VALUE "FileDescription", "Erase & Rewrite folder size treemap"
            VALUE "FileVersion", "1.0.0.0025"
            VALUE "InternalName", "eraserewrite"
            VALUE "LegalCopyright", "See repository license"
            VALUE "OriginalFilename", "EraseAndRewrite.exe"
            VALUE "ProductName", "Erase & Rewrite"
            VALUE "ProductVersion", "1.0.0.0025"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END