#!/bin/sh
# Runs after every local commit. On branch PUBLISH_BRANCH, runs PUBLISH_SCRIPT from repo root.
# Enable once per clone: see .githooks/README.md

PUBLISH_BRANCH="${PUBLISH_BRANCH:-pub}"
PUBLISH_SCRIPT="${PUBLISH_SCRIPT:-./publish.sh}"

repo_root=$(git rev-parse --show-toplevel) || exit 0
cd "$repo_root" || exit 0

branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null) || exit 0
[ "$branch" = "$PUBLISH_BRANCH" ] || exit 0

if [ ! -f "$PUBLISH_SCRIPT" ]; then
	printf '%s\n' "post-commit: on branch '$PUBLISH_BRANCH' but '$PUBLISH_SCRIPT' not found; skipping." >&2
	exit 0
fi

printf '%s\n' "post-commit: branch '$PUBLISH_BRANCH' -> running $PUBLISH_SCRIPT" >&2
exec sh "$PUBLISH_SCRIPT"
